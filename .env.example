# FlowOwl — environment variables
# Copy this file to .env and fill in your values

# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Required: Clerk backend secret key (from dashboard.clerk.com → API Keys)
CLERK_SECRET_KEY=sk_live_...

# Recommended for custom Clerk domains: JWKS Public Key (from dashboard.clerk.com → API Keys → JWKS Public Key)
# Paste the full PEM key (-----BEGIN PUBLIC KEY----- ... -----END PUBLIC KEY-----)
# This bypasses the JWKS network fetch, which can fail in serverless environments
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Required: Stripe secret key (for pro subscription checks)
STRIPE_SECRET_KEY=sk_live_...

# Required: PostgreSQL connection string (for session stats)
DATABASE_URL=postgresql://...

# Optional: comma-separated list of hardcoded pro user IDs
NEXT_PUBLIC_PAID_USER_IDS=user_abc,user_def

# Optional: port for the local server (default: 3000)
PORT=3000
